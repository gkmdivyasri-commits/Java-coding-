#include <stdio.h>

struct Cart {
    float itemPrice;
    int quantity;
};

// Function to calculate total cost
float calculateTotal(struct Cart c) {
    float total = c.itemPrice * c.quantity;

    if (total > 5000) {
        total = total - (total * 0.10);  // 10% discount
    }

    return total;
}

int main() {
    struct Cart cart;

    // Input
    cart.itemPrice = 1200;
    cart.quantity = 5;

    // Output
    printf("%.0f", calculateTotal(cart));

    return 0;
}